{
  "name": "talkcapital",
  "version": "0.1.0",
  "description": "15分講演音声から手書き風グラレコPNGを生成するCLI",
  "type": "module",
  "bin": {
    "talkcapital": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node dist/index.js",
    "prepare": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.888.0",
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/client-transcribe": "^3.888.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "commander": "^14.0.1",
    "dotenv": "^17.2.2",
    "nanoid": "^5.1.5",
    "playwright": "^1.55.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  }
}
